# ===================================================================
# GovTech Platform - Environment Configuration Template
# Copy to .env and fill in actual values for your deployment
# ===================================================================

# --- APPLICATION SETTINGS ---
APP_NAME="Citizen Policy Intelligence Platform"
ENV="development"  # development, staging, production
# SECURITY: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="CHANGE_ME_GENERATE_NEW_SECRET_KEY_MIN_32_CHARS"

# --- API SERVER ---
API_HOST="0.0.0.0"
API_PORT=8000

# --- ADMIN CREDENTIALS (for hardcoded admin account) ---
# SECURITY: Use strong, random password! Change from defaults!
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME_STRONG_ADMIN_PASSWORD"

# --- DEMO CREDENTIALS (for demo account) ---
# SECURITY: Use strong, random password!
DEMO_USERNAME="demo"
DEMO_PASSWORD="CHANGE_ME_STRONG_DEMO_PASSWORD"

# --- DATABASE: PostgreSQL (Primary - Recommended) ---
# Format: postgresql://username:password@host:port/database
# SECURITY: Use strong password! Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DATABASE_URL="postgresql://admin:CHANGE_ME_STRONG_PASSWORD@localhost:5432/gov_db"

# Alternative: SQLite (for local development only, not recommended for production)
# DATABASE_URL="sqlite:///./citizen_policy.db"

# --- CACHE & BROKER: Redis ---
# Format: redis://[:password]@host:port/db
REDIS_URL="redis://localhost:6379/0"

# --- GRAPH DATABASE: Neo4j (Optional - for relationship analysis) ---
# SECURITY: Use strong password!
NEO4J_URL="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# --- OBJECT STORAGE: MinIO (Optional - for file uploads) ---
# SECURITY: Change from default ***REMOVED*** credentials!
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="CHANGE_ME_NEW_ACCESS_KEY"
MINIO_SECRET_KEY="CHANGE_ME_NEW_SECRET_KEY"
MINIO_SECURE=false

# --- SEARCH ENGINE: Meilisearch (Optional - for full-text search) ---
# SECURITY: Generate strong API key!
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="CHANGE_ME_MEILISEARCH_API_KEY"

# --- CELERY: Background Tasks & Scheduling ---
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# --- AI MODELS: Hugging Face (for sentiment analysis, summarization) ---
# These are model paths that will be downloaded from huggingface.co
SENTIMENT_MODEL_PATH="j-hartmann/emotion-english-distilroberta-base"
SUMMARIZATION_MODEL_PATH="facebook/bart-large-cnn"

# --- AI MODELS: Google Gemini (for E-Paper generation) ---
GEMINI_API_KEY="your-gemini-api-key-from-google-cloud"

# --- NLP BACKEND SERVICE ---
NLP_BASE_URL="http://127.0.0.1:8001"
NLP_TIMEOUT=10

# --- EXTERNAL APIs ---
# Google News RSS Feed API (for live news aggregation)
GOOGLE_NEWS_API_KEY="optional-api-key"

# News API (alternative news source)
NEWS_API_KEY="optional-api-key"

# --- EMAIL CONFIGURATION (for notifications) ---
# SECURITY: Use app-specific password, not your actual password!
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="CHANGE_ME_YOUR_EMAIL@gmail.com"
SMTP_PASSWORD="CHANGE_ME_APP_SPECIFIC_PASSWORD"
SMTP_FROM="noreply@govtech-platform.com"

# --- LOGGING ---
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT="json"  # json or text

# --- CORS & SECURITY ---
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000"
ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOW_CREDENTIALS=true

# --- RATE LIMITING ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=60  # seconds

# --- PAGINATION DEFAULTS ---
DEFAULT_LIMIT=20
MAX_LIMIT=100

# --- FILE UPLOADS ---
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
UPLOAD_DIRECTORY="./uploads"
ALLOWED_EXTENSIONS="pdf,jpg,jpeg,png,csv,json"

# --- CELERY BEAT SCHEDULE ---
CELERY_ENABLE_BEAT=true
# Update live news every hour
CELERY_NEWS_UPDATE_SCHEDULE=3600
# Generate E-Paper daily at 6 AM
CELERY_EPAPER_SCHEDULE="0 6 * * *"  # cron format

# --- FEATURE FLAGS ---
ENABLE_NLP_SENTIMENT=true
ENABLE_NEO4J_GRAPH=false
ENABLE_MINIO_STORAGE=false
ENABLE_MEILISEARCH=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PRODUCTION_MODE=false

# --- DEBUG MODE (NEVER enable in production) ---
DEBUG=false
TESTING=false

# ===================================================================
# INSTRUCTIONS TO SETUP:
# ===================================================================
#
# 1. Copy this file: cp .env.example .env
# 2. Update values for your environment
# 3. For PostgreSQL setup:
#    createdb -U postgres
#    CREATE DATABASE gov_db;
#    CREATE USER admin WITH PASSWORD '***REMOVED***';
#    GRANT ALL PRIVILEGES ON DATABASE gov_db TO admin;
#
# 4. For Redis:
#    docker run -d -p 6379:6379 redis:latest
#    # OR: brew install redis && redis-server
#
# 5. For Google Gemini API:
#    - Go to https://makersuite.google.com/app/apikey
#    - Create API key
#    - Paste here
#
# 6. Start application:
#    uvicorn app.main:app --reload --port 8000
#
# ===================================================================
