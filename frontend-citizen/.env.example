# ===================================================================
# Frontend Citizen - Environment Configuration Template
# Copy to .env and fill in actual values for your deployment
# ===================================================================

# --- API ENDPOINTS ---
# Backend API base URL
VITE_API_URL=http://localhost:8000/api/v1

# NLP Backend URL (for advanced features)
VITE_NLP_API_URL=http://localhost:8001/api

# --- GOOGLE GEMINI API ---
# SECURITY: Frontend Gemini API key (if using direct API calls)
# RECOMMENDED: Use backend API instead to keep key secure
# WARNING: Exposing API key in frontend code is a security risk!
VITE_GEMINI_API_KEY=CHANGE_ME_FRONTEND_GEMINI_KEY

# --- ANALYTICS & MONITORING ---
# Google Analytics tracking ID (optional)
VITE_GOOGLE_ANALYTICS_ID=

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# --- FEATURE FLAGS ---
VITE_ENABLE_VOICE_COMMANDS=true
VITE_ENABLE_NLP_FEATURES=true
VITE_ENABLE_ADVANCED_ANALYTICS=true

# --- UI CONFIGURATION ---
VITE_APP_NAME="Citizen Policy Intelligence"
VITE_APP_VERSION=1.0.0

# --- LOGGING ---
VITE_LOG_LEVEL=info  # debug, info, warn, error

# ===================================================================
# SECURITY RECOMMENDATIONS:
# ===================================================================
# 1. API Keys in frontend are EXPOSED to users
# 2. For sensitive operations, use backend API instead
# 3. Don't put database credentials here
# 4. Don't put admin keys here
# 5. Use .env.local for local development (in .gitignore)
# 6. NEVER commit real API keys
# 
# Setup Instructions:
# ===================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Edit .env.local with your values
# 3. .env.local is in .gitignore (never committed)
# 4. Restart dev server after changes
# ===================================================================
