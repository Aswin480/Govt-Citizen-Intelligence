# ===================================================================
# NLP Backend - Environment Configuration Template
# Copy to .env and fill in actual values for your deployment
# ===================================================================

# --- DJANGO SETTINGS ---
ENV=development  # development, staging, production

# --- SECURITY: Django Secret Key ---
# SECURITY: Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY="CHANGE_ME_GENERATE_NEW_DJANGO_SECRET_KEY"

# --- DEBUG MODE ---
# SECURITY: NEVER set to True in production!
DJANGO_DEBUG=1

# --- ALLOWED HOSTS ---
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1,localhost:8001"

# --- DATABASE: PostgreSQL ---
# Format: postgresql://username:password@host:port/database
# SECURITY: Use strong password!
DATABASE_URL="postgresql://admin:CHANGE_ME_STRONG_PASSWORD@localhost:5432/gov_nlp_db"

# --- CACHE & BROKER: Redis ---
REDIS_URL="redis://localhost:6379/1"

# --- NLP SERVICE SETTINGS ---
NLP_PORT=8001
NLP_HOST=0.0.0.0

# --- LOGGING ---
LOG_LEVEL=INFO

# --- CORS & SECURITY ---
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:8000,http://127.0.0.1:5173,http://127.0.0.1:8000"

# --- MAX FILE SIZE FOR UPLOADS ---
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# ===================================================================
# Setup Instructions:
# ===================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values (use strong passwords!)
# 3. NEVER commit .env to Git
# 4. Verify .env is in .gitignore
# 5. Restart services after changes
# ===================================================================
